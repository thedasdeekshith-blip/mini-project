import requests
import json
import os
import time
from datetime import datetime

# Configuration and Constants
BASE_URL = "https://hacker-news.firebaseio.com/v0"
HEADERS = {"User-Agent": "TrendPulse/1.0"}
DATA_DIR = "data"
LIMIT_PER_CATEGORY = 25
TOP_STORIES_LIMIT = 500

# Keyword mapping for categorization
CATEGORIES = {
    "technology": ["ai", "software", "tech", "code", "computer", "data", "cloud", "api", "gpu", "llm"],
    "worldnews": ["war", "government", "country", "president", "election", "climate", "attack", "global"],
    "sports": ["nfl", "nba", "fifa", "sport", "game", "team", "player", "league", "championship"],
    "science": ["research", "study", "space", "physics", "biology", "discovery", "nasa", "genome"],
    "entertainment": ["movie", "film", "music", "netflix", "game", "book", "show", "award", "streaming"]
}

def get_category(title):
    """Checks the title against keywords to assign a category."""
    title_lower = title.lower()
    for category, keywords in CATEGORIES.items():
        if any(keyword in title_lower for keyword in keywords):
            return category
    return None

def fetch_data():
    # 1. Create data directory if it doesn't exist
    if not os.path.exists(DATA_DIR):
        os.makedirs(DATA_DIR)
    
    # 2. Fetch top story IDs
    try:
        print("Fetching top stories list...")
        response = requests.get(f"{BASE_URL}/topstories.json", headers=HEADERS)
        response.raise_for_status()
        story_ids = response.json()[:TOP_STORIES_LIMIT]
    except Exception as e:
        print(f"Failed to fetch story IDs: {e}")
        return

    collected_data = []
    # Dictionary to track count per category
    counts = {cat: 0 for cat in CATEGORIES}

    # 3. Process stories
    print("Processing stories and categorizing...")
    
    # We iterate through categories to satisfy the 2-second sleep requirement
    for category_name in CATEGORIES.keys():
        print(f"Searching for stories in category: {category_name}...")
        
        for s_id in story_ids:
            # Stop if we hit the limit for this specific category
            if counts[category_name] >= LIMIT_PER_CATEGORY:
                break
                
            try:
                item_url = f"{BASE_URL}/item/{s_id}.json"
                item_res = requests.get(item_url, headers=HEADERS)
                item_res.raise_for_status()
                story = item_res.json()

                # Safety check: ensure item is a story and has a title
                if not story or 'title' not in story:
                    continue

                # Check if this story fits the CURRENT category loop
                assigned_cat = get_category(story['title'])
                
                if assigned_cat == category_name:
                    # Extract required fields (Task 2 requirement)
                    record = {
                        "post_id": story.get("id"),
                        "title": story.get("title"),
                        "category": assigned_cat,
                        "score": story.get("score", 0),
                        "num_comments": story.get("descendants", 0),
                        "author": story.get("by"),
                        "collected_at": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                    }
                    collected_data.append(record)
                    counts[category_name] += 1
            
            except Exception as e:
                print(f"Error fetching item {s_id}: {e}")
                continue
        
        # Requirement: Wait 2 seconds between each category loop
        time.sleep(2)

    # 4. Save to JSON
    date_str = datetime.now().strftime("%Y%m%d")
    filename = f"{DATA_DIR}/trends_{date_str}.json"
    
    with open(filename, 'w') as f:
        json.dump(collected_data, f, indent=4)

    print(f"\nCollected {len(collected_data)} stories. Saved to {filename}")

if __name__ == "__main__":
    fetch_data()